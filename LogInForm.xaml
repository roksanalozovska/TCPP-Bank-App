<Window x:Class="BankClients.LogInForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankClients"
        mc:Ignorable="d"
        Title="Авторизація" Height="270" Width="350">
    <Grid Background="#F4F4F4">
        <StackPanel Margin="20" VerticalAlignment="Center">
            <TextBlock Text="Вхід у систему" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>

            <Label Content="Логін:"/>
            <TextBox x:Name="logTextBox" Margin="0,0,0,10" Padding="3"/>

            <Label Content="Пароль:"/>
            <PasswordBox x:Name="passwordTextBox" Margin="0,0,0,20" Padding="3"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button x:Name="okButton" Content="Увійти" Width="100" Height="30" 
                        Background="#007ACC" Foreground="White" Margin="5" Click="OkButton_Click"/>

                <Button x:Name="cancelButton" Content="Скасувати" Width="100" Height="30" 
                        Background="#E0E0E0" Foreground="Black" Margin="5" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>